# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the keys you have. Every connector
# degrades gracefully (skips itself + logs a warning) if its key is missing,
# so you can start with just ONE platform and add more later.
# ---------------------------------------------------------------------------

# Database (SQLite by default -- fine for prototype / small production use)
DATABASE_URL=sqlite:///./data/social_intel.db

# --- X / Twitter API v2 -----------------------------------------------------
# Get a bearer token at https://developer.x.com (pay-per-use as of 2026,
# ~$0.005 per post read, 7-day recent search only on self-serve tiers).
X_BEARER_TOKEN=

# --- Meta Ad Library API (public, official, no App Review needed for the
# ads_archive endpoint) -----------------------------------------------------
# Create an app at https://developers.facebook.com and generate a token.
META_ACCESS_TOKEN=
META_AD_LIBRARY_COUNTRY=US

# --- News / web mentions (any NewsAPI-compatible provider) ------------------
# https://newsapi.org has a free developer tier, good enough for a prototype.
NEWS_API_KEY=

# --- Anthropic API (used for content classification + sentiment) -----------
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Polling cadence ---------------------------------------------------------
POLL_INTERVAL_MINUTES=60
